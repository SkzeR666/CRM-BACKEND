NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Chave usada pelo admin frontend (x-admin-key)
ADMIN_API_KEY=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# Habilite somente se quiser permitir x-admin-key em producao
# (se false, producao exige sessao autenticada do Supabase)
ALLOW_ADMIN_KEY_IN_PRODUCTION=false

# URLs liberadas no CORS (separe por virgula)
FRONTEND_ORIGIN=http://localhost:3000,https://crm-frontend-one-lovat.vercel.app
